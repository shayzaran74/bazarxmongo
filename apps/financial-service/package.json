{
  "name": "@barterborsa/financial-service",
  "version": "1.0.0",
  "private": true,
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/apps/financial-service/src/main",
    "dev": "nest start --watch --exec \"node -r ts-node/register -r tsconfig-paths/register src/main.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@barterborsa/shared-core": "workspace:*",
    "@barterborsa/shared-messaging": "workspace:*",
    "@barterborsa/shared-nest": "workspace:*",
    "@barterborsa/shared-observability": "workspace:*",
    "@barterborsa/shared-persistence": "workspace:*",
    "@barterborsa/shared-security": "workspace:*",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.8",
    "@golevelup/nestjs-rabbitmq": "^5.1.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/mongoose": "^10.0.6",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-fastify": "^10.3.7",
    "@nestjs/platform-socket.io": "^10.3.8",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/terminus": "^10.2.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.3.8",
    "@prisma/client": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.4.3",
    "ioredis": "^5.3.2",
    "prisma": "^5.12.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",

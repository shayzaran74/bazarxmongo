{
  "name": "@barterborsa/financial-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/apps/financial-service/src/main",
    "dev": "nest start --watch --exec \"node -r ts-node/register -r tsconfig-paths/register src/main.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@barterborsa/shared-core": "workspace:*",
    "@barterborsa/shared-messaging": "workspace:*",
    "@barterborsa/shared-nest": "workspace:*",
    "@barterborsa/shared-observability": "workspace:*",
    "@barterborsa/shared-persistence": "workspace:*",
    "@barterborsa/shared-security": "workspace:*",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.8",
    "@golevelup/nestjs-rabbitmq": "^5.1.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@prisma/client": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.4.3",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/node": "^20.0.0",
    "prisma": "^5.12.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.0.0"
  }
}

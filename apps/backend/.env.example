# apps/backend/.env.example
# Kopyala: cp .env.example .env.development
# Tüm değerleri doldur, asla gerçek değerlerle commit etme

NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3002

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

RABBITMQ_URL=amqp://USER:PASSWORD@localhost:5672
RABBITMQ_USER=barterborsa
RABBITMQ_PASSWORD=change_me

JWT_SECRET=change_me_min_32_chars
JWT_REFRESH_SECRET=change_me_min_32_chars_different
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=bazarx-media

GRPC_HOST=localhost
GRPC_PORT=50051
FINANCIAL_SERVICE_URL=localhost:50051

MONGODB_URI=mongodb://USER:PASSWORD@localhost:27017/bazarxmongo?authSource=admin

IYZICO_API_KEY=sandbox-your-key
IYZICO_SECRET_KEY=sandbox-your-secret
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

CSRF_SECRET=change_me_min_32_chars

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=change_me
SMTP_PASSWORD=change_me
SMTP_FROM=noreply@bazarx.local

# ── Finansal mutabakat (capture hedefi platform hesabı) ──────────────
# BazarXGO sipariş ödemesi: restoranın payoutAccountId'si yoksa buraya capture edilir
BAZARXGO_PLATFORM_ACCOUNT_ID=change_me
# Barter komisyon blokajı (kapalıyken komisyon alınmaz)
BARTER_COMMISSION_HOLD_ENABLED=false
BARTER_COMMISSION_PLATFORM_ACCOUNT_ID=change_me

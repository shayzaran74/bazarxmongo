model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique @map("invoice_number")
  orderId        String        @map("order_id")
  type           InvoiceType
  recipientId    String        @map("recipient_id")   // userId veya vendorId
  recipientType  RecipientType @map("recipient_type") // BUYER veya VENDOR
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @db.Decimal(18, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(18, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(18, 2)
  currency       String        @default("TRY")
  pdfUrl         String?       @map("pdf_url")
  pdfGeneratedAt DateTime?     @map("pdf_generated_at")
  issuedAt       DateTime      @default(now()) @map("issued_at")
  dueAt          DateTime?     @map("due_at")
  notes          String?
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  order          Order         @relation(fields: [orderId], references: [id])
  items          InvoiceItem[]

  @@index([orderId])
  @@index([recipientId])
  @@index([status])
  @@map("invoices")
}


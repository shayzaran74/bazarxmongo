// ─── B2C Abonelik Sistemi ──────────────────────────────────────────────

// 8 kademe abonelik planı tanımı (seed data ile doldurulur)
model MembershipPlan {
  id            String           @id @default(cuid())
  tier          SubscriptionTier @unique
  monthlyFee    Decimal          @map("monthly_fee")     @db.Decimal(18, 2)
  annualFee     Decimal?         @map("annual_fee")      @db.Decimal(18, 2) // 10 ay fiyatına 12 ay
  menuCredit    Decimal          @map("menu_credit")     @db.Decimal(18, 2) // 2× aylık aidat
  breakeven     Decimal          @map("breakeven")       @db.Decimal(18, 2) // aylık breakeven ciro
  benefits      Json?
  isActive      Boolean          @default(true)          @map("is_active")
  createdAt     DateTime         @default(now())         @map("created_at")
  updatedAt     DateTime         @updatedAt              @map("updated_at")
  subscriptions UserSubscription[]

  @@map("membership_plans")
}

// Kullanıcı başına aktif abonelik
model UserSubscription {
  id                      String             @id @default(cuid())
  userId                  String             @unique @map("user_id")
  planId                  String             @map("plan_id")
  status                  SubscriptionStatus @default(TRIAL)
  startDate               DateTime           @map("start_date")
  endDate                 DateTime           @map("end_date")
  autoRenew               Boolean            @default(true) @map("auto_renew")
  nextBillingDate         DateTime?          @map("next_billing_date")
  cancelledAt             DateTime?          @map("cancelled_at")
  downgradeProtectedUntil DateTime?          @map("downgrade_protected_until") // 30 gün menü hakkı devam eder
  referralDiscountPct     Decimal            @default(0) @map("referral_discount_pct") @db.Decimal(5, 2) // 3. referans: %20
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  plan                    MembershipPlan     @relation(fields: [planId], references: [id])
  menuUsages              MenuUsage[]

  @@index([userId])
  @@index([status])
  @@map("user_subscriptions")
}

// Aylık menü hakkı kullanım takibi
model MenuUsage {
  id             String           @id @default(cuid())
  subscriptionId String           @map("subscription_id")
  month          Int
  year           Int
  usedCredit     Decimal          @default(0) @map("used_credit") @db.Decimal(18, 2)
  totalCredit    Decimal          @map("total_credit")             @db.Decimal(18, 2) // 2× aidat
  subscription   UserSubscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, month, year])
  @@map("menu_usages")
}


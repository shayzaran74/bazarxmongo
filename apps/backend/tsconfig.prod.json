{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../../",
    "baseUrl": ".",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "paths": {
      "@barterborsa/shared-core": ["../../packages/shared/shared-core/src/index"],
      "@barterborsa/shared-types": ["../../packages/shared/shared-types/src/index"],
      "@barterborsa/shared-persistence": ["../../packages/shared/shared-persistence/src/index"],
      "@barterborsa/shared-security": ["../../packages/shared/shared-security/src/index"],
      "@barterborsa/shared-messaging": ["../../packages/shared/shared-messaging/src/index"],
      "@barterborsa/shared-observability": ["../../packages/shared/shared-observability/src/index"],
      "@barterborsa/shared-queue": ["../../packages/shared/shared-queue/src/index"],
      "@barterborsa/shared-nest": ["../../packages/shared/shared-nest/src/index"],
      "@barterborsa/domain-identity": ["../../packages/domain/domain-identity/src/index"]
    }
  },
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}

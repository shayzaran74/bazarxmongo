{
  "name": "@bazarx/backend",
  "version": "1.0.0",
  "description": "BazarX API V1 Core",
  "private": true,
  "type": "commonjs",
  "files": [
    "dist",
    "prisma"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "nest start --watch --exec \"node -r ts-node/register -r tsconfig-paths/register src/main.ts\"",
    "start": "node dist/apps/backend/src/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/backend/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node --project tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@barterborsa/domain-identity": "workspace:*",
    "@barterborsa/shared-core": "workspace:*",
    "@barterborsa/shared-messaging": "workspace:*",
    "@barterborsa/shared-nest": "workspace:*",
    "@barterborsa/shared-observability": "workspace:*",
    "@barterborsa/shared-persistence": "workspace:*",
    "@barterborsa/shared-queue": "workspace:*",
    "@barterborsa/shared-security": "workspace:*",
    "@barterborsa/shared-types": "workspace:*",
    "@fastify/static": "^7.0.1",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.8",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-fastify": "^10.3.7",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "5.12.0",
    "bcrypt": "^5.1.1",
    "blurhash": "^2.0.5",
    "bullmq": "^5.76.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "decimal.js": "^10.4.3",
    "ioredis": "^5.4.1",
    "minio": "^8.0.7",
    "mongoose": "^8.3.2",
    "@nestjs/mongoose": "^10.0.6",
    "@nestjs/terminus": "^10.2.1",
    "@nestjs/websockets": "^10.3.8",
    "@nestjs/platform-socket.io": "^10.3.8",
    "socket.io": "^4.7.5",
    "express": "^4.19.2",
    "uuid": "^9.0.1",
    "@golevelup/nestjs-rabbitmq": "^5.1.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5",
    "prisma": "5.12.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/sharp": "^0.31.1",

    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json prisma/seed.ts"
  }
}

{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@barterborsa/shared-core": [
        "../../packages/shared/shared-core/src/index"
      ],
      "@barterborsa/shared-messaging": [
        "../../packages/shared/shared-messaging/src/index"
      ],
      "@barterborsa/shared-observability": [
        "../../packages/shared/shared-observability/src/index"
      ],
      "@barterborsa/shared-persistence": [
        "../../packages/shared/shared-persistence/src/index"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}

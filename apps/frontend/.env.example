# apps/frontend/.env.example
# Kopyala: cp .env.example .env.development

NUXT_PUBLIC_API_BASE=http://localhost:3001
NUXT_BACKEND_URL=http://localhost:3001
# NUXT_PUBLIC_MINIO_BASE kaldırıldı; tüm public görseller artık /api/v1/media/{objectKey} stream proxy adresi üzerinden, 
# özel/private belgeler ise signed URL ile doğrudan çekilmektedir.
NUXT_PUBLIC_SOCKET_URL=
NUXT_PUBLIC_APP_NAME=BazarX
NUXT_PUBLIC_IYZICO_API_KEY=sandbox-your-key-here
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

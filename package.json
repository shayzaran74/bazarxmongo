  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "debug": "4.3.4",
      "esbuild": "0.27.7"
    }
  }

{
  "name": "barterborsa-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "env:local": "cp apps/frontend/.env.development apps/frontend/.env && cp apps/backend/.env.development apps/backend/.env",
    "env:server": "cp apps/frontend/.env.production apps/frontend/.env && cp apps/backend/.env.production apps/backend/.env",
    "env:ngrok": "cp apps/frontend/.env.ngrok apps/frontend/.env",
    "prisma:studio": "cd apps/backend && npx prisma studio",
    "prisma:migrate": "cd apps/backend && npx prisma migrate dev",
    "prisma:generate": "cd apps/backend && npx prisma generate",
    "ngrok:backend": "ngrok http 3001",
    "ngrok:frontend": "ngrok http 3002",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "docker:up": "docker-compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infra/docker-compose.yml down",
    "docker:logs": "docker-compose -f infra/docker-compose.yml logs -f",
    "docker:status": "docker-compose -f infra/docker-compose.yml ps"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/opossum": "^8.1.9",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "prettier": "^3.2.0",
    "prisma": "5.12.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "debug": "4.3.4",
      "esbuild": "0.27.7",
      "@nestjs/bullmq": "11.0.4",
      "bullmq": "5.76.2"
    }
  }
}
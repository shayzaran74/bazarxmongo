# BazarX Production Environment Variables — ÖRNEK DOSYA
# Bu dosyayı .env.prod olarak kopyalayıp gerçek değerleri girin
# cp .env.prod.example .env.prod

# ─── Domain ──────────────────────────────────────────────
DOMAIN=bazarx.info
MINIO_DOMAIN=storage.bazarx.info

# ─── CORS (virgülle ayırın) ───────────────────────────────
CORS_ORIGIN=https://bazarx.info,https://www.bazarx.info
WS_CORS_ORIGIN=https://bazarx.info,https://www.bazarx.info

# ─── Nuxt Frontend ───────────────────────────────────────
NUXT_PUBLIC_API_BASE=https://bazarx.info/api

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=bazarx_pg_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bazarx_production

# ─── MongoDB ─────────────────────────────────────────────
MONGO_USER=bazarx_mongo_user
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_DB=bazarxmongo

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── RabbitMQ ────────────────────────────────────────────
RABBITMQ_USER=bazarx_mq_user
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── JWT (en az 64 karakter, rastgele üretin) ────────────
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_REFRESH_SECRET

# ─── MinIO ───────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# ─── Iyzico (Ödeme) ──────────────────────────────────────
IYZICO_API_KEY=CHANGE_ME_IYZICO_API_KEY
IYZICO_SECRET_KEY=CHANGE_ME_IYZICO_SECRET_KEY
IYZICO_BASE_URL=https://api.iyzipay.com

# ─── Financial Service (gRPC) ────────────────────────────
FINANCIAL_GRPC_URL=financial-service:50051

# ─── Backend ─────────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=production
APP_VERSION=1.0.0

# ─── Sentry (Hata Takibi) ─────────────────────────────────
# https://sentry.io adresinden DSN alın
SENTRY_DSN=https://CHANGE_ME@CHANGE_ME.ingest.sentry.io/CHANGE_ME

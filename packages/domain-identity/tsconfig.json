{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@barterborsa/shared-core": ["../shared/shared-core/dist/index"],
      "@barterborsa/shared-persistence": ["../shared/shared-persistence/dist/index"],
      "@barterborsa/shared-security": ["../shared/shared-security/dist/index"],
      "@barterborsa/shared-types": ["../shared/shared-types/dist/index"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ]
}

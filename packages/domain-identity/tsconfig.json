{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@barterborsa/shared-core": [
        "../shared/shared-core/dist/index.d.ts"
      ],
      "@barterborsa/shared-persistence": [
        "../shared/shared-persistence/dist/index.d.ts"
      ],
